Proceso ejercicio1
	definir mililitros,quimA,quimB como real;
	Escribir "Ingrese la cantidad de Mililitros comprados:";
	Leer mililitros;
	quimA = (mililitros*2.55)/1000;
	quimB = (mililitros*5.78)/1000;
	Escribir "Se debe agregar ", quimA," gramos del compuesto A y ", quimB, " del B en ", mililitros, " mililitros" ;
FinProceso
